<!DOCTYPE html>
<html lang="pt-BR" dir="ltr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  {{-- SEO Base --}}
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <meta name="googlebot" content="index, follow">
  <meta name="description" content="Portal oficial da Câmara Municipal de Sumé - PB. Transparência, notícias, atividades legislativas, vereadores e serviços ao cidadão.">
  <meta name="keywords" content="Câmara Municipal, Sumé, Paraíba, vereadores, legislativo, transparência, licitações, atas, sessões plenárias">
  <meta name="author" content="Câmara Municipal de Sumé">

  {{-- Open Graph --}}
  <meta property="og:type" content="website">
  <meta property="og:locale" content="pt_BR">
  <meta property="og:site_name" content="Câmara Municipal de Sumé">
  <meta property="og:title" content="Câmara Municipal de Sumé - Portal Oficial">
  <meta property="og:description" content="Portal oficial da Câmara Municipal de Sumé - PB. Transparência, notícias, atividades legislativas e serviços ao cidadão.">
  <meta property="og:url" content="https://node.camaradesume.pb.gov.br">
  <meta property="og:image" content="https://node.camaradesume.pb.gov.br/og-image.jpg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  {{-- Twitter Card --}}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Câmara Municipal de Sumé - Portal Oficial">
  <meta name="twitter:description" content="Portal oficial da Câmara Municipal de Sumé - PB. Transparência, notícias e serviços ao cidadão.">
  <meta name="twitter:image" content="https://node.camaradesume.pb.gov.br/og-image.jpg">

  {{-- Canonical --}}
  <link rel="canonical" href="https://node.camaradesume.pb.gov.br{{ request.url() }}">

  {{-- Favicon --}}
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/manifest.json">

  {{-- Theme --}}
  <meta name="theme-color" content="#1a2332">
  <meta name="msapplication-TileColor" content="#1a2332">

  {{-- Acessibilidade: aplica modo escuro / alto contraste / escala de fonte salvos
       ANTES do primeiro paint (anti-flash). Default do tema segue prefers-color-scheme.
       O painel administrativo (/painel) não usa esses modos. --}}
  <script>
    (function () {
      try {
        if (window.location.pathname.indexOf('/painel') === 0) return
        var el = document.documentElement
        var theme = localStorage.getItem('theme')
        var dark = theme === 'dark' || (!theme && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches)
        if (dark) el.classList.add('dark')
        if (localStorage.getItem('contrast') === 'high') el.classList.add('high-contrast')
        var fs = localStorage.getItem('fontScale')
        if (fs === '2' || fs === '3') el.setAttribute('data-font-scale', fs)
        // Estilo de layout (forma/tipografia/densidade) — reaplica antes do
        // paint a partir do valor persistido pelo DynamicTheme. Default
        // 'institucional' não tem overrides; 1ª visita pode ter leve flash.
        el.setAttribute('data-layout', localStorage.getItem('layoutStyle') || 'institucional')
        // Modelo do site (estrutura do header/home) — reaplica antes do paint.
        el.setAttribute('data-template', localStorage.getItem('siteTemplate') || 'institucional')
      } catch (e) {}
    })()
  </script>

  {{-- Preconnect to image CDN if applicable --}}

  {{-- Structured Data: Organization --}}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "GovernmentOrganization",
    "name": "Câmara Municipal de Sumé",
    "alternateName": "Câmara de Vereadores de Sumé",
    "url": "https://node.camaradesume.pb.gov.br",
    "logo": "https://node.camaradesume.pb.gov.br/uploads/logo-camara-sume.png",
    "description": "Câmara Municipal de Sumé, Paraíba. Casa Vereador Cícero Soares. Poder Legislativo Municipal.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Centro",
      "addressLocality": "Sumé",
      "addressRegion": "PB",
      "postalCode": "58540-000",
      "addressCountry": "BR"
    },
    "areaServed": {
      "@type": "City",
      "name": "Sumé",
      "containedInPlace": {
        "@type": "State",
        "name": "Paraíba"
      }
    },
    "sameAs": []
  }
  </script>

  {{-- Structured Data: WebSite with SearchAction --}}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Câmara Municipal de Sumé",
    "url": "https://node.camaradesume.pb.gov.br",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://node.camaradesume.pb.gov.br/noticias?busca={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  @inertiaHead()
  @vite(['inertia/app/app.tsx'])
</head>
<body>
  @inertia()

  {{-- VLibras (tradução para Língua Brasileira de Sinais) — widget oficial do
       governo carregado em TODO o site, independente do React/SSR (presente em
       qualquer página, inclusive o painel). Inicializa direto aqui no layout
       raiz; a barra de acessibilidade (AccessibilityBar.tsx) apenas mostra/
       esconde este mesmo widget. Respeita a preferência do usuário (localStorage
       'vlibras' = 'off') e não aparece em conteúdo embedado em modais (?embed=1). --}}
  <div vw class="enabled" style="display: none">
    <div vw-access-button class="active"></div>
    <div vw-plugin-wrapper>
      <div class="vw-plugin-top-wrapper"></div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/gh/spbgovbr-vlibras/vlibras-portal@sgd/app/vlibras-plugin.js?v=20260510"></script>
  <script>
    (function () {
      function startVLibras() {
        var container = document.querySelector('[vw]')
        try {
          // Não exibe dentro de conteúdo embedado (modais da transparência)
          if (/[?&]embed=1/.test(window.location.search)) {
            if (container) container.style.display = 'none'
            return
          }
          var off = false
          try { off = localStorage.getItem('vlibras') === 'off' } catch (e) {}
          if (off) {
            if (container) container.style.display = 'none'
            return
          }
          if (window.VLibras && window.VLibras.Widget) {
            if (!window.__vlibrasWidget) {
              new window.VLibras.Widget('https://vlibras.gov.br/app')
              window.__vlibrasWidget = true
            }
            if (container) container.style.display = ''
          }
        } catch (e) {}
      }
      if (window.VLibras && window.VLibras.Widget) startVLibras()
      else window.addEventListener('load', startVLibras)
    })()
  </script>
</body>
</html>
