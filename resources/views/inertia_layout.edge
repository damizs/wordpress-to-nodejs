<!DOCTYPE html>
<html lang="pt-BR" dir="ltr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  {{-- SEO Base --}}
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <meta name="googlebot" content="index, follow">
  {{-- Identidade (nome/cidade/UF/domínio) vem de `camara`, compartilhado pelo
       share_view_data_middleware (config/camara). Descrição/keywords são montadas
       a partir desses globais — sem nenhuma câmara chumbada. --}}
  <meta name="description" content="Portal oficial da {{ camara.nome }}, {{ camara.cidade }} - {{ camara.uf }}. Transparência, notícias, atividades legislativas, vereadores e serviços ao cidadão.">
  <meta name="keywords" content="{{ camara.nome }}, {{ camara.cidade }}, {{ camara.uf }}, vereadores, legislativo, transparência, licitações, atas, sessões plenárias">
  <meta name="author" content="{{ camara.nome }}">

  {{-- Open Graph --}}
  <meta property="og:type" content="website">
  <meta property="og:locale" content="pt_BR">
  <meta property="og:site_name" content="{{ camara.nome }}">
  <meta property="og:title" content="{{ camara.nome }} - Portal Oficial">
  <meta property="og:description" content="Portal oficial da {{ camara.nome }}, {{ camara.cidade }} - {{ camara.uf }}. Transparência, notícias, atividades legislativas e serviços ao cidadão.">
  <meta property="og:url" content="{{ camara.baseUrl }}">
  <meta property="og:image" content="{{ camara.baseUrl }}/og-image.jpg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  {{-- Twitter Card --}}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ camara.nome }} - Portal Oficial">
  <meta name="twitter:description" content="Portal oficial da {{ camara.nome }}, {{ camara.cidade }} - {{ camara.uf }}. Transparência, notícias e serviços ao cidadão.">
  <meta name="twitter:image" content="{{ camara.baseUrl }}/og-image.jpg">

  {{-- Canonical --}}
  <link rel="canonical" href="{{ camara.baseUrl }}{{ request.url() }}">

  {{-- Favicon --}}
  {{-- Favicon enviado no painel (Aparência) renderizado já no 1º paint via
       share_view_data_middleware → ctx.view.share. Os <link> estáticos abaixo
       são FALLBACK quando não há favicon configurado. O DynamicFavicon reforça
       o swap no client com o mesmo cache-buster estável. --}}
  @if(faviconUrl)
    <link rel="icon" type="{{ faviconType || 'image/png' }}" href="{{ faviconUrl }}">
    <link rel="apple-touch-icon" href="{{ faviconUrl }}">
  @else
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  @endif
  <link rel="manifest" href="/manifest.json">

  {{-- Theme --}}
  <meta name="theme-color" content="#1a2332">
  <meta name="msapplication-TileColor" content="#1a2332">

  {{-- Acessibilidade: aplica modo escuro / alto contraste / escala de fonte salvos
       ANTES do primeiro paint (anti-flash). Padrão SEMPRE claro; escuro só por opt-in do usuário.
       O painel administrativo (/painel) não usa esses modos. --}}
  <script>
    (function () {
      try {
        if (window.location.pathname.indexOf('/painel') === 0) return
        var el = document.documentElement
        var theme = localStorage.getItem('theme')
        var dark = theme === 'dark'
        if (dark) el.classList.add('dark')
        if (localStorage.getItem('contrast') === 'high') el.classList.add('high-contrast')
        var fs = localStorage.getItem('fontScale')
        if (fs === '2' || fs === '3') el.setAttribute('data-font-scale', fs)
        // Estilo de layout (forma/tipografia/densidade) — reaplica antes do
        // paint a partir do valor persistido pelo DynamicTheme. Default
        // 'institucional' não tem overrides; 1ª visita pode ter leve flash.
        el.setAttribute('data-layout', localStorage.getItem('layoutStyle') || 'institucional')
        // Modelo do site (estrutura do header/home) — reaplica antes do paint.
        el.setAttribute('data-template', localStorage.getItem('siteTemplate') || 'institucional')
      } catch (e) {}
    })()
  </script>

  {{-- Preconnect to image CDN if applicable --}}

  {{-- Structured Data: Organization --}}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "GovernmentOrganization",
    "name": "{{ camara.nome }}",
    "alternateName": "Câmara de Vereadores de {{ camara.cidade }}",
    "url": "{{ camara.baseUrl }}",
    "logo": "{{ camara.baseUrl }}/og-image.jpg",
    "description": "{{ camara.nome }}, {{ camara.cidade }} - {{ camara.uf }}. Poder Legislativo Municipal.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Centro",
      "addressLocality": "{{ camara.cidade }}",
      "addressRegion": "{{ camara.uf }}",
      "postalCode": "58540-000",
      "addressCountry": "BR"
    },
    "areaServed": {
      "@type": "City",
      "name": "{{ camara.cidade }}",
      "containedInPlace": {
        "@type": "State",
        "name": "{{ camara.uf }}"
      }
    },
    "sameAs": []
  }
  </script>

  {{-- Structured Data: WebSite with SearchAction --}}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ camara.nome }}",
    "url": "{{ camara.baseUrl }}",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ camara.baseUrl }}/noticias?busca={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  @inertiaHead()
  @vite(['inertia/app/app.tsx'])
</head>
<body>
  {{-- Skip-link e-MAG: PRIMEIRO elemento focável da página (antes do app), levando
       ao <main id="conteudo">. Oculto no painel. --}}
  @if(!request.url().includes('/painel'))
    <a href="#conteudo" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-gold focus:text-navy-dark focus:px-4 focus:py-2 focus:rounded-lg focus:font-semibold focus:no-underline focus:shadow-lg">Pular para o conteúdo</a>
  @endif
  @inertia()

  {{-- VLibras (tradução para Língua Brasileira de Sinais) — widget oficial do
       governo carregado em TODO o site, independente do React/SSR (presente em
       qualquer página, inclusive o painel). Inicializa direto aqui no layout
       raiz; a barra de acessibilidade (AccessibilityBar.tsx) apenas mostra/
       esconde este mesmo widget. Respeita a preferência do usuário (localStorage
       'vlibras' = 'off') e não aparece em conteúdo embedado em modais (?embed=1). --}}
  <div vw class="enabled" style="display: none">
    <div vw-access-button class="active"></div>
    <div vw-plugin-wrapper>
      <div class="vw-plugin-top-wrapper"></div>
    </div>
  </div>
  {{-- Ancora o widget VLibras FIRMEMENTE no canto inferior direito em TODOS os
       viewports (mobile, tablet e desktop). O widget oficial nasce centralizado
       à direita (posição arrastável que o plugin grava como style inline) e cobre
       conteúdo de leitura/botões em ~14 páginas. Aqui forçamos o BOTÃO de acesso
       ([vw-access-button]) E o painel do player ([vw-plugin-wrapper]) para o canto,
       empilhados ACIMA dos FABs de assistente (bottom-6) e acessibilidade
       (bottom-24) no desktop, e 2 passos acima do dock no mobile. O !important
       sobrescreve o estilo inline do plugin; targetamos os filhos (que são
       position:fixed próprios) e não só o [vw]. NÃO mexe no esconder em ?embed=1
       nem no toggle por localStorage (controlados no script abaixo). --}}
  <style>
    /* Container: âncora no canto, sem ocupar/cobrir espaço; sem transform
       (transform no [vw] criaria containing block e quebraria os filhos fixed). */
    [vw] {
      position: fixed !important;
      inset: auto 0 0 auto !important;
      width: auto !important;
      height: auto !important;
      transform: none !important;
      z-index: 45 !important;
    }
    /* Botão de acesso e painel do player ancorados ao viewport, no canto. */
    [vw] [vw-access-button],
    [vw] [vw-plugin-wrapper] {
      position: fixed !important;
      top: auto !important;
      left: auto !important;
      /* Footprint menor p/ cobrir menos conteúdo no canto (ainda é FAB flutuante). */
      transform: scale(0.72) !important;
      transform-origin: bottom right;
    }
    /* Desktop/tablet (>= 640px, mesmo breakpoint sm: dos FABs):
       assistente em bottom-6 e acessibilidade em bottom-24 → VLibras acima. */
    @media (min-width: 640px) {
      [vw] [vw-access-button],
      [vw] [vw-plugin-wrapper] {
        right: 1.5rem !important;
        bottom: 10.5rem !important;
      }
    }
    /* Mobile (< 640px): empilha 2 passos acima do dock
       (assistente = passo 0, acessibilidade = passo 1, VLibras = passo 2),
       no mesmo canto direito; escala leve para caber, ancorada no canto. */
    @media (max-width: 639.98px) {
      [vw] [vw-access-button],
      [vw] [vw-plugin-wrapper] {
        right: var(--mobile-dock-right, 0.75rem) !important;
        bottom: calc(
          var(--mobile-dock-bottom, 0.875rem) +
          2 * var(--mobile-dock-step, 3.625rem)
        ) !important;
        transform: scale(0.82);
      }
    }
  </style>
  <script src="https://cdn.jsdelivr.net/gh/spbgovbr-vlibras/vlibras-portal@sgd/app/vlibras-plugin.js?v=20260510"></script>
  <script>
    (function () {
      function startVLibras() {
        var container = document.querySelector('[vw]')
        try {
          // Não exibe dentro de conteúdo embedado (modais da transparência)
          if (/[?&]embed=1/.test(window.location.search)) {
            if (container) container.style.display = 'none'
            return
          }
          var off = false
          try { off = localStorage.getItem('vlibras') === 'off' } catch (e) {}
          if (off) {
            if (container) container.style.display = 'none'
            return
          }
          if (window.VLibras && window.VLibras.Widget) {
            if (!window.__vlibrasWidget) {
              new window.VLibras.Widget('https://vlibras.gov.br/app')
              window.__vlibrasWidget = true
            }
            if (container) container.style.display = ''
          }
        } catch (e) {}
      }
      if (window.VLibras && window.VLibras.Widget) startVLibras()
      else window.addEventListener('load', startVLibras)
    })()
  </script>
</body>
</html>
